# ============================================================
# Agent V3 Insta — .env.example
# Скопировать в .env и заполнить реальными значениями
# ============================================================

# --- Instagram / Meta ---
IG_ACCOUNT_ID=17841419820082008
IG_VERIFY_TOKEN=your-verify-token-here
IG_APP_SECRET=your-instagram-app-secret
IG_ACCESS_TOKEN=IGAA...long-lived-token

# --- PostgreSQL (gateway) ---
DATABASE_URL=postgresql://mg_user:mg_secure_2026@postgres:5432/messaging_gateway

# --- PostgreSQL (Agent V3) ---
AGENT_DATABASE_URL=postgresql://erp_user:erp_password@127.0.0.1:5432/erp_db

# --- Agent V3 ---
BOT_BRAIN_URL=https://brain.yourdomain.com/invoke
BOT_BRAIN_SECRET=generate-with-openssl-rand-hex-32

# --- AI Providers ---
DEEPSEEK_API_KEY=sk-...
DEEPINFRA_API_KEY=...

# --- Domain ---
DOMAIN=gateway.yourdomain.com
BRAIN_DOMAIN=brain.yourdomain.com

# --- Optional: outbound proxy for Meta (if server is in Russia) ---
OUTBOUND_PROXY=
